{
  "name": "brightwheel-front-desk",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "pages:dev": "wrangler pages dev",
    "pages:deploy": "npm run build && wrangler pages deploy",
    "db:local": "wrangler d1 execute brightwheel-front-desk-db --local --file=./schema.sql",
    "db:remote": "wrangler d1 execute brightwheel-front-desk-db --remote --file=./schema.sql"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250121.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "wrangler": "^3.99.0"
  }
}
